# .env template for OpenClaw / dev-env-toolkit
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to git (already in .gitignore)

# --- QClaw LLM Proxy (primary model route) ---
QCLAW_LLM_BASE_URL=https://your-llm-proxy-url-here.com/v1
QCLAW_LLM_API_KEY=sk-your-qclaw-llm-api-key-here

# --- OpenRouter API ---
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# --- DeepSeek API ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# --- WeChat Access (for openclaw-weixin channel) ---
QCLAW_WECHAT_WS_URL=wss://your-wechat-ws-url-here

# --- Feishu (Lark) App Credentials ---
# Account 1 (cli_aa8783e887789cce)
QCLAW_FEISHU_ACCOUNT_CLI_AA8783E887789CCE_APPID=cli_your_app_id_here
QCLAW_FEISHU_ACCOUNT_CLI_AA8783E887789CCE_APPSECRET=your_app_secret_here

# Account 2 (cli_aa9b87680eb8dccd)
QCLAW_FEISHU_ACCOUNT_CLI_AA9B87680EB8DCCD_APPID=cli_your_app_id_here
QCLAW_FEISHU_ACCOUNT_CLI_AA9B87680EB8DCCD_APPSECRET=your_app_secret_here

# Account 3 (cli_aa9b87fc02f8dcc7)
QCLAW_FEISHU_ACCOUNT_CLI_AA9B87FC02F8DCC7_APPID=cli_your_app_id_here
QCLAW_FEISHU_ACCOUNT_CLI_AA9B87FC02F8DCC7_APPSECRET=your_app_secret_here


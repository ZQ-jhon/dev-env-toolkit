# Environment variables for OpenClaw dev-env-toolkit
# Copy .env.template to .env and fill in your keys, then:
#   Windows PowerShell:  Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'User') } }
#   macOS/Linux bash:     export $(grep -v '^#' .env | xargs)

# This file should NOT be committed to git.
# It is listed in .gitignore.
